{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermit_Purple",
  "version": "0.5.0",
  "identifier": "com.softandoweto.hermit-purple",
  "build": {
    "beforeDevCommand": "yarn start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist/hermit-purple/browser"
  },
  "app": {
    "windows": [
      {
        "title": "Hermit Purple",
        "width": 1000,
        "height": 1200
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwRkVBNjVBRjdBNDdCMkQKUldRdGU2VDNXcWIra05DZWtMNktlUHJ5U0g4R1VDMUF4Q08vZWpTYlV2Nkd5N2JyN24xZXZyVEsK",
      "endpoints": [
        "https://raw.githubusercontent.com/SoftAndoWeto/hermit-purple/main/updates/latest.json"
      ]
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
